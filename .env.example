# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
APP_URL=""

# PORT: Port where the backend server runs.
PORT=3000

# MONGODB_URI: Connection string for MongoDB Atlas or local MongoDB.
MONGODB_URI=""

# JWT_SECRET: Secret key used to sign JSON Web Tokens for administrative auth.
JWT_SECRET="your_jwt_secret_here"

# EMAIL_USER & EMAIL_PASS: Used by Nodemailer to dispatch visitor notifications.
EMAIL_USER=""
EMAIL_PASS=""

# GITHUB_USERNAME: Your GitHub profile user handle to pull public repositories dynamically.
GITHUB_USERNAME=""

# CLIENT_URL: URL of the portfolio frontend client.
CLIENT_URL="http://localhost:3000"